# Python bytecode & caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Secrets / env files — never bake these in
.env
.env.*
*.env

# Dev tooling & VCS
.git/
.gitignore
*.md
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
tests/

# Large ML artefacts — loaded at runtime from volume or regenerated on startup
*.pkl
*.joblib
*.h5
*.pt
*.pth

# Virtual envs — use the Dockerfile venv, never the host one
.venv/
venv/
env/
