# Python bytecode & caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Secrets / env files — never bake these in
.env
.env.*
*.env

# Dev tooling & VCS
.git/
.gitignore
*.md
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
tests/

# Large ML artefacts that ARE regenerated/not needed at build time.
# NOTE: ml/questionnaire_model.pkl and ml/encoders.pkl are loaded directly
# from disk at runtime (see ml/inference.py) and must NOT be excluded here --
# a blanket "*.pkl" rule used to silently break model loading in any deploy
# without the dev-only ./backend:/app volume mount papering over it.
*.h5
*.pt
*.pth

# Virtual envs — use the Dockerfile venv, never the host one
.venv/
venv/
env/
