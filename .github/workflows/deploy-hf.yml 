name: Deploy to Hugging Face Space

on:
  push:
    branches:
      - ayush

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          lfs: true

      - name: Push to Hugging Face Space
        env:
          HF_TOKEN: ${{ secrets.HF_TOKEN }}
          HF_USERNAME: ${{ secrets.HF_USERNAME }}
          SPACE_NAME: autiscreen
        run: |
          git config --global user.email "deploy@autiscreen.ai"
          git config --global user.name "AutiScreen Deploy Bot"

          # Clone the HF Space repo
          git clone https://$HF_USERNAME:$HF_TOKEN@huggingface.co/spaces/$HF_USERNAME/$SPACE_NAME hf_space
          cd hf_space

          # Sync everything from our repo into the Space
          rsync -av --delete \
            --exclude='.git' \
            --exclude='mobile/' \
            --exclude='ml/data/' \
            --exclude='*.md' \
            --exclude='.github/' \
            ../ ./

          # HF Space needs Dockerfile named exactly "Dockerfile"
          cp Dockerfile.hf Dockerfile

          git add -A
          git diff --cached --quiet && echo "No changes to deploy" && exit 0

          git commit -m "Deploy from GitHub: ${{ github.sha }}"
          git push
          echo "✅ Deployed to https://huggingface.co/spaces/$HF_USERNAME/$SPACE_NAME"